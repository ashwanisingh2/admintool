<ui:FluentWindow
    x:Class="SysAdminX.Shell.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:dashViews="clr-namespace:SysAdminX.Dashboard.Views;assembly=SysAdminX.Dashboard"
    xmlns:devViews="clr-namespace:SysAdminX.DeviceDetails.Views;assembly=SysAdminX.DeviceDetails"
    xmlns:drvViews="clr-namespace:SysAdminX.DriverManager.Views;assembly=SysAdminX.DriverManager"
    xmlns:ptcViews="clr-namespace:SysAdminX.PatchManager.Views;assembly=SysAdminX.PatchManager"
    xmlns:netViews="clr-namespace:SysAdminX.NetworkToolkit.Views;assembly=SysAdminX.NetworkToolkit"
    xmlns:trbViews="clr-namespace:SysAdminX.Troubleshooting.Views;assembly=SysAdminX.Troubleshooting"
    xmlns:aiViews="clr-namespace:SysAdminX.AIAssistant.Views;assembly=SysAdminX.AIAssistant"
    xmlns:rptViews="clr-namespace:SysAdminX.Reports.Views;assembly=SysAdminX.Reports"
    xmlns:setViews="clr-namespace:SysAdminX.Settings.Views;assembly=SysAdminX.Settings"
    xmlns:logViews="clr-namespace:SysAdminX.LogsViewer.Views;assembly=SysAdminX.LogsViewer"
    xmlns:secViews="clr-namespace:SysAdminX.SecurityCenter.Views;assembly=SysAdminX.SecurityCenter"
    xmlns:rsViews="clr-namespace:SysAdminX.RemoteSupport.Views;assembly=SysAdminX.RemoteSupport"
    xmlns:batViews="clr-namespace:SysAdminX.BatteryManager.Views;assembly=SysAdminX.BatteryManager"
    xmlns:svcViews="clr-namespace:SysAdminX.ServiceManager.Views;assembly=SysAdminX.ServiceManager"
    xmlns:clnViews="clr-namespace:SysAdminX.SystemCleanup.Views;assembly=SysAdminX.SystemCleanup"
    xmlns:sftViews="clr-namespace:SysAdminX.SoftwareManager.Views;assembly=SysAdminX.SoftwareManager"
    xmlns:prtViews="clr-namespace:SysAdminX.PortableTools.Views;assembly=SysAdminX.PortableTools"
    xmlns:occViews="clr-namespace:SysAdminX.OneClickCare.Views;assembly=SysAdminX.OneClickCare"
    xmlns:apViews="clr-namespace:SysAdminX.AutoPilot.Views;assembly=SysAdminX.AutoPilot"
    xmlns:srViews="clr-namespace:SysAdminX.SystemRestore.Views;assembly=SysAdminX.SystemRestore"
    xmlns:pcViews="clr-namespace:SysAdminX.PrivacyCleaner.Views;assembly=SysAdminX.PrivacyCleaner"
    xmlns:brViews="clr-namespace:SysAdminX.BrowserRepair.Views;assembly=SysAdminX.BrowserRepair"
    xmlns:pmViews="clr-namespace:SysAdminX.PerformanceMode.Views;assembly=SysAdminX.PerformanceMode"
    xmlns:smViews="clr-namespace:SysAdminX.StartupManager.Views;assembly=SysAdminX.StartupManager"
    xmlns:lffViews="clr-namespace:SysAdminX.LargeFileFinder.Views;assembly=SysAdminX.LargeFileFinder"
    xmlns:rmViews="clr-namespace:SysAdminX.RegistryManager.Views;assembly=SysAdminX.RegistryManager"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    mc:Ignorable="d"
    Title="SysAdminX — IT Admin Toolkit"
    Width="1280"
    Height="800"
    MinWidth="1024"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    StateChanged="Window_StateChanged">

    <Grid>
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="/Resources/icon.ico"
            ToolTipText="SysAdminX"
            Visibility="Collapsed"
            TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="TrayIconOpen_Click" />
                    <MenuItem Header="Exit" Click="TrayIconExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Title="SysAdminX"
            ShowMaximize="True"
            ShowMinimize="True"
            CanMaximize="True" />

        <!-- Navigation View (Sidebar + Content) -->
        <ui:NavigationView
            x:Name="NavigationView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Auto"
            IsPaneToggleVisible="True"
            OpenPaneLength="260">

            <!-- Navigation Menu Items -->
            <ui:NavigationView.MenuItems>
                <!-- Dashboard -->
                <ui:NavigationViewItem
                    x:Name="NavDashboard"
                    Content="Dashboard"
                    Icon="{ui:SymbolIcon Home24}"
                    TargetPageType="{x:Type dashViews:DashboardView}"
                    IsActive="True" />



                <!-- Device Details -->
                <ui:NavigationViewItem
                    x:Name="NavDeviceDetails"
                    Content="Device Details"
                    Icon="{ui:SymbolIcon Desktop24}"
                    TargetPageType="{x:Type devViews:DeviceDetailsView}" />

                <!-- Driver Manager -->
                <ui:NavigationViewItem
                    x:Name="NavDriverManager"
                    Content="Driver Manager"
                    Icon="{ui:SymbolIcon PlugDisconnected24}"
                    TargetPageType="{x:Type drvViews:DriverManagerView}" />

                <!-- Patch Manager -->
                <ui:NavigationViewItem
                    x:Name="NavPatchManager"
                    Content="Patch Manager"
                    Icon="{ui:SymbolIcon ArrowDownload24}"
                    TargetPageType="{x:Type ptcViews:PatchManagerView}" />

                <!-- Battery Manager -->
                <ui:NavigationViewItem
                    x:Name="NavBatteryManager"
                    Content="Battery Manager"
                    Icon="{ui:SymbolIcon BatteryCharge24}"
                    TargetPageType="{x:Type batViews:BatteryManagerView}" />

                <!-- Network Toolkit -->
                <ui:NavigationViewItem
                    x:Name="NavNetworkToolkit"
                    Content="Network Toolkit"
                    Icon="{ui:SymbolIcon Globe24}"
                    TargetPageType="{x:Type netViews:NetworkToolkitView}" />

                <!-- Troubleshooting -->
                <ui:NavigationViewItem
                    x:Name="NavTroubleshooting"
                    Content="Troubleshooting"
                    Icon="{ui:SymbolIcon Wrench24}"
                    TargetPageType="{x:Type trbViews:TroubleshootingView}" />

                <!-- Service Manager -->
                <ui:NavigationViewItem
                    x:Name="NavServiceManager"
                    Content="Service Manager"
                    Icon="{ui:SymbolIcon WindowApps24}"
                    TargetPageType="{x:Type svcViews:ServiceManagerView}" />

                <!-- System Cleanup -->
                <ui:NavigationViewItem
                    x:Name="NavSystemCleanup"
                    Content="System Cleanup"
                    Icon="{ui:SymbolIcon Delete24}"
                    TargetPageType="{x:Type clnViews:SystemCleanupView}" />

                <!-- Software Manager -->
                <ui:NavigationViewItem
                    x:Name="NavSoftwareManager"
                    Content="Software Manager"
                    Icon="{ui:SymbolIcon Apps24}"
                    TargetPageType="{x:Type sftViews:SoftwareManagerView}" />

                <!-- Portable Tools -->
                <ui:NavigationViewItem
                    x:Name="NavPortableTools"
                    Content="Portable Tools"
                    Icon="{ui:SymbolIcon Toolbox24}"
                    TargetPageType="{x:Type prtViews:PortableToolsView}" />

                <!-- One Click Care -->
                <ui:NavigationViewItem
                    x:Name="NavOneClickCare"
                    Content="One Click Care"
                    Icon="{ui:SymbolIcon Heart24}"
                    TargetPageType="{x:Type occViews:OneClickCareView}" />

                <!-- Auto Pilot -->
                <ui:NavigationViewItem
                    x:Name="NavAutoPilot"
                    Content="Auto Pilot"
                    Icon="{ui:SymbolIcon Airplane24}"
                    TargetPageType="{x:Type apViews:AutoPilotView}" />

                <!-- System Restore -->
                <ui:NavigationViewItem
                    x:Name="NavSystemRestore"
                    Content="System Restore"
                    Icon="{ui:SymbolIcon History24}"
                    TargetPageType="{x:Type srViews:SystemRestoreView}" />

                <!-- Privacy Cleaner -->
                <ui:NavigationViewItem
                    x:Name="NavPrivacyCleaner"
                    Content="Privacy Cleaner"
                    Icon="{ui:SymbolIcon ShieldCheckmark24}"
                    TargetPageType="{x:Type pcViews:PrivacyCleanerView}" />

                <!-- Browser Repair -->
                <ui:NavigationViewItem
                    x:Name="NavBrowserRepair"
                    Content="Browser Repair"
                    Icon="{ui:SymbolIcon Globe24}"
                    TargetPageType="{x:Type brViews:BrowserRepairView}" />

                <!-- Performance Mode -->
                <ui:NavigationViewItem
                    x:Name="NavPerformanceMode"
                    Content="Performance Mode"
                    Icon="{ui:SymbolIcon Flash24}"
                    TargetPageType="{x:Type pmViews:PerformanceModeView}" />

                <!-- Startup Manager -->
                <ui:NavigationViewItem
                    x:Name="NavStartupManager"
                    Content="Startup Manager"
                    Icon="{ui:SymbolIcon Timer24}"
                    TargetPageType="{x:Type smViews:StartupManagerView}" />

                <!-- Large File Finder -->
                <ui:NavigationViewItem
                    x:Name="NavLargeFileFinder"
                    Content="Large File Finder"
                    Icon="{ui:SymbolIcon DocumentSearch24}"
                    TargetPageType="{x:Type lffViews:LargeFileFinderView}" />

                <!-- Registry Manager -->
                <ui:NavigationViewItem
                    x:Name="NavRegistryManager"
                    Content="Registry Manager"
                    Icon="{ui:SymbolIcon DocumentText24}"
                    TargetPageType="{x:Type rmViews:RegistryManagerView}" />

                <!-- AI Assistant -->
                <ui:NavigationViewItem
                    x:Name="NavAIAssistant"
                    Content="AI Assistant"
                    Icon="{ui:SymbolIcon Bot24}"
                    TargetPageType="{x:Type aiViews:AIAssistantView}" />



                <!-- Remote Support -->
                <ui:NavigationViewItem
                    x:Name="NavRemoteSupport"
                    Content="Remote Support"
                    Icon="{ui:SymbolIcon Desktop24}"
                    TargetPageType="{x:Type rsViews:RemoteSupportView}" />

                <!-- Reports -->
                <ui:NavigationViewItem
                    x:Name="NavReports"
                    Content="Reports"
                    Icon="{ui:SymbolIcon DocumentPrint24}"
                    TargetPageType="{x:Type rptViews:ReportsView}" />
            </ui:NavigationView.MenuItems>

            <!-- Footer Items -->
            <ui:NavigationView.FooterMenuItems>
                <!-- Logs -->
                <ui:NavigationViewItem
                    x:Name="NavLogs"
                    Content="Logs Viewer"
                    Icon="{ui:SymbolIcon TextBulletListSquare24}"
                    TargetPageType="{x:Type logViews:LogsViewerView}" />

                <!-- Security Center -->
                <ui:NavigationViewItem
                    x:Name="NavSecurity"
                    Content="Security Center"
                    Icon="{ui:SymbolIcon Shield24}"
                    TargetPageType="{x:Type secViews:SecurityCenterView}" />

                <!-- Settings -->
                <ui:NavigationViewItem
                    x:Name="NavSettings"
                    Content="Settings"
                    Icon="{ui:SymbolIcon Settings24}"
                    TargetPageType="{x:Type setViews:SettingsView}" />
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>

</ui:FluentWindow>
