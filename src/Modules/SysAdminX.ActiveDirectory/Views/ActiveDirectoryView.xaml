<Page
    x:Class="SysAdminX.ActiveDirectory.Views.ActiveDirectoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.ActiveDirectory.ViewModels"
    mc:Ignorable="d"
    Title="Active Directory"
    d:DataContext="{d:DesignInstance vm:ActiveDirectoryViewModel, IsDesignTimeCreatable=False}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <Style x:Key="EnabledIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="Symbol" Value="DismissCircle24" />
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Enabled}" Value="True">
                    <Setter Property="Symbol" Value="CheckmarkCircle24" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Active Directory"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Query users and groups in the current AD Domain using RSAT PowerShell."
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
        
        <!-- Warning Banner -->
        <ui:InfoBar Grid.Row="1" Title="RSAT Missing or Not Domain Joined"
                    Message="The ActiveDirectory PowerShell module could not be found or executed. Ensure RSAT is installed and the PC is domain joined."
                    Severity="Warning" IsOpen="{Binding IsMissingRsat}" Margin="0,0,0,20" />

        <!-- Search Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <ui:TextBox Grid.Column="0" 
                        PlaceholderText="Search by Name or sAMAccountName (leave empty for all)" 
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                        Icon="Search24" 
                        ClearButtonEnabled="True" 
                        Margin="0,0,16,0" />
                        
            <ui:Button Grid.Column="1" Command="{Binding SearchCommand}" Appearance="Primary" Width="100">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Search24" Margin="0,0,8,0" />
                    <TextBlock Text="Search" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            
            <ui:ProgressRing Grid.ColumnSpan="3" IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

            <!-- Users List -->
            <Border Grid.Column="0" 
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    x:Name="UsersBorder">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                    
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="Person24" Margin="0,0,8,0"/>
                        <TextBlock Text="Users" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Status" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ui:SymbolIcon Style="{StaticResource EnabledIconStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Username" Binding="{Binding SamAccountName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Groups List -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    x:Name="GroupsBorder">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                    
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="People24" Margin="0,0,8,0"/>
                        <TextBlock Text="Groups" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Groups}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Scope" Binding="{Binding GroupScope}" Width="80" />
                            <DataGridTextColumn Header="Category" Binding="{Binding GroupCategory}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
