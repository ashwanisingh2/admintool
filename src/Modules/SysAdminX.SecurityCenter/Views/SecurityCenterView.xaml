<Page
    x:Class="SysAdminX.SecurityCenter.Views.SecurityCenterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.SecurityCenter.ViewModels"
    mc:Ignorable="d"
    Title="Security Center"
    d:DataContext="{d:DesignInstance vm:SecurityCenterViewModel, IsDesignTimeCreatable=False}">

    <Page.Resources>
        <!-- A quick converter to map booleans to Green/Red colors -->
        <Style x:Key="StatusIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="Symbol" Value="ErrorCircle24" />
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="True">
                    <Setter Property="Symbol" Value="CheckmarkCircle24" />
                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Security Center"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Monitor endpoint security policies, Defender status, and BitLocker encryption."
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
            
            <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding LoadDataCommand}" Appearance="Secondary">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowCounterclockwise24" Margin="0,0,8,0" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Loading Progress -->
                <ui:ProgressRing IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Margin="0,0,0,20" />

                <!-- Windows Defender -->
                <TextBlock Text="Windows Defender" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Service -->
                        <ui:SymbolIcon Grid.Row="0" Grid.Column="0" DataContext="{Binding DefenderStatus.IsEnabled}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Antimalware Service" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding DefenderStatus.IsEnabled}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                        <!-- Real-time -->
                        <ui:SymbolIcon Grid.Row="1" Grid.Column="0" DataContext="{Binding DefenderStatus.IsRealTimeProtectionEnabled}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Real-Time Protection" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DefenderStatus.IsRealTimeProtectionEnabled}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                        <!-- Signature -->
                        <ui:SymbolIcon Grid.Row="2" Grid.Column="0" Symbol="Shield24" Foreground="{DynamicResource SystemFillColorNeutralBrush}" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Signature Version" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="{Binding DefenderStatus.AntivirusSignatureVersion}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DefenderStatus.AntivirusSignatureLastUpdated, StringFormat=' (Last updated: {0:g})'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Status -->
                        <ui:SymbolIcon Grid.Row="3" Grid.Column="0" Symbol="Info24" Foreground="{DynamicResource SystemFillColorNeutralBrush}" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Product State" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding DefenderStatus.ProductStatus}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Antivirus Products -->
                <TextBlock Text="Antivirus Products (WMI)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <ItemsControl ItemsSource="{Binding AntivirusProducts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <ui:SymbolIcon Grid.Column="0" Symbol="ShieldCheckmark24" Foreground="{DynamicResource SystemFillColorSuccessBrush}" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="State: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding ProductState}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AntivirusProducts.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="No additional Antivirus products found." Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </Border>

                <!-- BitLocker -->
                <TextBlock Text="BitLocker Drive Encryption" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <DataGrid ItemsSource="{Binding BitLockerVolumes}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              GridLinesVisibility="Horizontal" 
                              HeadersVisibility="Column"
                              RowBackground="Transparent"
                              AlternatingRowBackground="Transparent"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Drive" Binding="{Binding DriveLetter}" Width="80" />
                            <DataGridTextColumn Header="Type" Binding="{Binding VolumeType}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding ProtectionStatus}" Width="150" />
                            <DataGridTextColumn Header="Encryption" Binding="{Binding EncryptionMethod}" Width="180" />
                            <DataGridTemplateColumn Header="Progress" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center" Margin="0,0,16,0">
                                            <ProgressBar Value="{Binding EncryptionPercentage}" Maximum="100" Height="12" />
                                            <TextBlock Text="{Binding EncryptionPercentage, StringFormat={}{0:N0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                
                <!-- Windows Firewall -->
                <TextBlock Text="Windows Defender Firewall" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <ItemsControl ItemsSource="{Binding FirewallProfiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <ui:SymbolIcon Grid.Column="0" DataContext="{Binding IsEnabled}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left" />
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Inbound: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding DefaultInboundAction}" Margin="0,0,16,0" />
                                        <TextBlock Text="Outbound: " Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding DefaultOutboundAction}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- UAC Settings -->
                <TextBlock Text="User Account Control (UAC)" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- EnableLUA -->
                        <ui:SymbolIcon Grid.Row="0" Grid.Column="0" DataContext="{Binding UacStatus.IsEnabled}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="UAC Enabled (EnableLUA)" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding UacStatus.IsEnabled}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                        <!-- Consent Prompt -->
                        <ui:SymbolIcon Grid.Row="1" Grid.Column="0" Symbol="PersonLock24" Foreground="{DynamicResource SystemFillColorNeutralBrush}" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Admin Prompt Behavior" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding UacStatus.ConsentPromptBehavior}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Windows Update -->
                <TextBlock Text="Windows Update" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Row="0" Grid.Column="0" DataContext="{Binding WindowsUpdateStatus.ServiceEnabled}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Service Enabled" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding WindowsUpdateStatus.ServiceEnabled}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                        <ui:SymbolIcon Grid.Row="1" Grid.Column="0" Symbol="Search24" Foreground="{DynamicResource SystemFillColorNeutralBrush}" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Last Search Success" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding WindowsUpdateStatus.LastSearchSuccessDate, StringFormat='{}{0:g}'}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                        <ui:SymbolIcon Grid.Row="2" Grid.Column="0" Symbol="ArrowDownload24" Foreground="{DynamicResource SystemFillColorNeutralBrush}" HorizontalAlignment="Left" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Last Install Success" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding WindowsUpdateStatus.LastInstallationSuccessDate, StringFormat='{}{0:g}'}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Secure Boot -->
                <TextBlock Text="Secure Boot" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Row="0" Grid.Column="0" DataContext="{Binding SecureBootStatus.IsSupported}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Is Supported" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SecureBootStatus.IsSupported}" VerticalAlignment="Center" Margin="0,0,0,12"/>

                        <ui:SymbolIcon Grid.Row="1" Grid.Column="0" DataContext="{Binding SecureBootStatus.IsEnabled}" Style="{StaticResource StatusIconStyle}" HorizontalAlignment="Left"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Is Enabled" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SecureBootStatus.IsEnabled}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
