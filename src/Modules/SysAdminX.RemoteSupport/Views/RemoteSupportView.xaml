<Page
    x:Class="SysAdminX.RemoteSupport.Views.RemoteSupportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.RemoteSupport.ViewModels"
    mc:Ignorable="d"
    Title="Remote Support"
    d:DataContext="{d:DesignInstance vm:RemoteSupportViewModel, IsDesignTimeCreatable=False}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Remote Support"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Quickly connect to remote computers for troubleshooting and administration."
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Target Hostname Input -->
        <Grid Grid.Row="1" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <ui:TextBox Grid.Column="0" 
                        PlaceholderText="Enter Target Hostname or IP Address..." 
                        Text="{Binding TargetHostname, UpdateSourceTrigger=PropertyChanged}" 
                        Icon="Desktop24" 
                        ClearButtonEnabled="True" 
                        FontSize="16"
                        Padding="12,8" />
        </Grid>

        <!-- Tool Cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <WrapPanel Orientation="Horizontal" ItemWidth="300" ItemHeight="160">
                
                <!-- RDP Card -->
                <ui:CardAction Margin="0,0,16,16" Command="{Binding LaunchRdpCommand}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="24" Margin="0,0,12,0" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <TextBlock Text="Remote Desktop" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Launch mstsc.exe to establish a full interactive desktop session with the target machine." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </ui:CardAction>

                <!-- Computer Management Card -->
                <ui:CardAction Margin="0,0,16,16" Command="{Binding LaunchComputerManagementCommand}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Wrench24" FontSize="24" Margin="0,0,12,0" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <TextBlock Text="Computer Management" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Connect compmgmt.msc to manage remote Event Viewer, Services, Users, and Shared Folders." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </ui:CardAction>
                
                <!-- Remote Command Prompt Card -->
                <ui:CardAction Margin="0,0,16,16" Command="{Binding LaunchRemoteCommandPromptCommand}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Code24" FontSize="24" Margin="0,0,12,0" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <TextBlock Text="Remote Command Prompt" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Launch PsExec to open a remote command prompt as SYSTEM on the target endpoint." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </ui:CardAction>

                <!-- Remote PowerShell Card -->
                <ui:CardAction Margin="0,0,16,16" Command="{Binding LaunchRemotePowerShellCommand}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Terminal24" FontSize="24" Margin="0,0,12,0" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <TextBlock Text="Remote PowerShell" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Text="Launch PsExec to open a remote PowerShell session as SYSTEM on the target endpoint." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </ui:CardAction>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>
