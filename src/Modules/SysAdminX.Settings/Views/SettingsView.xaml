<Page
    x:Class="SysAdminX.Settings.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.Settings.ViewModels"
    mc:Ignorable="d"
    Title="Settings"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel, IsDesignTimeCreatable=False}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Configure global preferences for the toolkit."
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                
                <!-- Appearance -->
                <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Application Theme" FontWeight="SemiBold" />
                            <TextBlock Text="Select your preferred theme (Dark or Light)." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                        
                        <ComboBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" SelectedValue="{Binding Config.Theme}" SelectedValuePath="Content">
                            <ComboBoxItem Content="Dark" />
                            <ComboBoxItem Content="Light" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- General -->
                <TextBlock Text="General" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Start on Boot -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start on Boot" FontWeight="SemiBold" />
                                <TextBlock Text="Launch SysAdminX automatically when Windows starts." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding Config.StartOnBoot}" />
                        </Grid>

                        <!-- Compact Sidebar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Compact Sidebar" FontWeight="SemiBold" />
                                <TextBlock Text="Show only icons in the sidebar to save horizontal space." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding Config.CompactSidebar}" />
                        </Grid>

                        <!-- Auto-tail logs -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Auto-tail Logs" FontWeight="SemiBold" />
                                <TextBlock Text="Live-stream new log entries in the Logs Viewer using a file watcher." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding Config.LogAutoTail}" />
                        </Grid>

                        <!-- Check for updates on startup -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Check for Updates on Startup" FontWeight="SemiBold" />
                                <TextBlock Text="Contact GitHub on launch to see if a newer release is available." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding Config.CheckForUpdatesOnStartup}" />
                        </Grid>

                        <!-- Check now button -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Check for Updates Now" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UpdateStatusText, FallbackValue='Click to check GitHub for a newer release.'}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>

                            <ui:Button Grid.Column="1" VerticalAlignment="Center"
                                       Content="Check Now"
                                       Icon="{ui:SymbolIcon ArrowSync24}"
                                       Command="{Binding CheckForUpdatesCommand}"
                                       IsEnabled="{Binding IsCheckingUpdates, Converter={StaticResource InverseBoolConverter}}" />
                        </Grid>

                        <!-- Reports Directory -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Default Reports Directory" FontWeight="SemiBold" />
                                <TextBlock Text="Path where exported PDFs and JSONs are saved." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:TextBox Grid.Column="1" VerticalAlignment="Center" Text="{Binding Config.DefaultExportDirectory}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Modules -->
                <TextBlock Text="Visible Modules" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Toggle which modules appear in the sidebar. Hidden modules are still registered in DI — restart the app to apply changes."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding ModuleToggles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <!-- Tools Integration -->
                <TextBlock Text="Tools Integration" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="250" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Sysinternals Path" FontWeight="SemiBold" />
                            <TextBlock Text="Path to Sysinternals Suite (optional, unlocks advanced tools in Phase 2)." Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                        
                        <ui:TextBox Grid.Column="1" VerticalAlignment="Center" Text="{Binding Config.SysinternalsPath}" PlaceholderText="C:\SysinternalsSuite" />
                    </Grid>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0" Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
                        <ui:SymbolIcon Symbol="Checkmark24" Foreground="{DynamicResource SystemFillColorSuccessBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Settings Saved" Foreground="{DynamicResource SystemFillColorSuccessBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                    
                    <ui:Button Appearance="Primary" Command="{Binding SaveSettingsCommand}" Width="120">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" Margin="0,0,8,0" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
