<Page
    x:Class="SysAdminX.Reports.Views.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.Reports.ViewModels"
    mc:Ignorable="d"
    Title="Reports"
    d:DataContext="{d:DesignInstance vm:ReportsViewModel, IsDesignTimeCreatable=False}">
    
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="System Reports"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Export system state and hardware inventory into structured documents."
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Actions Panel -->
            <StackPanel Grid.Column="0">
                <ui:TextBlock FontTypography="Subtitle" Text="Generate New" Margin="0,0,0,12" />
                
                <!-- One-Click Audit Report -->
                <Grid Margin="0,0,0,12">
                    <ui:Button Command="{Binding GenerateHtmlAuditCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               MinHeight="60">
                        <StackPanel Orientation="Horizontal" Margin="8">
                            <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="28" Margin="0,0,12,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Generate Full System Audit Report" FontWeight="Bold" FontSize="15" />
                                <TextBlock Text="Instantly generates and opens a styled HTML report with full system details." Opacity="0.8" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Button>
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ui:ProgressRing IsIndeterminate="True" Margin="0,0,12,0" />
                            <TextBlock Text="Generating Report..." FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
                
                <ui:CardAction Command="{Binding GeneratePdfCommand}" Margin="0,0,0,12">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="DocumentPdf24" Margin="0,0,0,8" />
                        <TextBlock Text="Export to PDF" FontWeight="SemiBold" />
                        <TextBlock Text="Generates a human-readable PDF report containing current hardware specs and OS details."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Command="{Binding GenerateJsonCommand}" Margin="0,0,0,24">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="DocumentJavascript24" Margin="0,0,0,8" />
                        <TextBlock Text="Export to JSON" FontWeight="SemiBold" />
                        <TextBlock Text="Generates a raw JSON payload of the entire system state, suitable for automated ingestion."
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </ui:CardAction>
                
                <ui:Button Content="Refresh History" Command="{Binding LoadHistoryCommand}" Appearance="Secondary" HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- History Panel -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                               Text="Saved Reports" 
                               FontWeight="SemiBold" 
                               FontSize="16" 
                               Margin="0,0,0,16" />
                               
                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding Reports}" 
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <ui:CardAction Command="{Binding DataContext.OpenReportCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <ui:SymbolIcon Grid.Column="0" 
                                                       Symbol="Document24" 
                                                       Margin="0,0,12,0" 
                                                       VerticalAlignment="Center" />
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" 
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                                       FontSize="12" 
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding GeneratedAt, StringFormat='g'}" 
                                                   Foreground="{DynamicResource TextFillColorDisabledBrush}" 
                                                   FontSize="11" 
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </ui:CardAction>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
