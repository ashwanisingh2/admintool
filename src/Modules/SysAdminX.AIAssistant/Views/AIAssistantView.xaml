<Page
    x:Class="SysAdminX.AIAssistant.Views.AIAssistantView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.AIAssistant.ViewModels"
    mc:Ignorable="d"
    Title="AI Assistant"
    d:DataContext="{d:DesignInstance vm:AIAssistantViewModel, IsDesignTimeCreatable=False}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Chat Bubble DataTemplateSelector could be used, but we'll keep it simple with triggers -->
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Local AI Assistant"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Offline-first LLM integration via Ollama or LM Studio"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Endpoint:" Width="60" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBox Text="{Binding Config.EndpointUrl}" Width="250" Margin="0,0,16,0" />
                    <TextBlock Text="Model:" Width="50" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBox Text="{Binding Config.ModelName}" Width="120" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="API Key:" Width="60" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:PasswordBox Password="{Binding Config.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="436" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Main Chat Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Prompts) -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Quick Prompts" FontWeight="SemiBold" Margin="0,0,0,12" />
                
                <ui:Button Command="{Binding LoadTemplateCommand}" CommandParameter="LogAnalyzer" 
                           HorizontalAlignment="Stretch" Margin="0,0,0,8" Appearance="Secondary">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:SymbolIcon Symbol="TextBulletListSquare24" Margin="0,0,8,0" />
                        <TextBlock Text="Event Log Analyzer" />
                    </StackPanel>
                </ui:Button>

                <ui:Button Command="{Binding LoadTemplateCommand}" CommandParameter="ScriptGenerator" 
                           HorizontalAlignment="Stretch" Margin="0,0,0,8" Appearance="Secondary">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:SymbolIcon Symbol="Document24" Margin="0,0,8,0" />
                        <TextBlock Text="PS Script Generator" />
                    </StackPanel>
                </ui:Button>
                
                <ui:Button Command="{Binding LoadTemplateCommand}" CommandParameter="ClearChat" 
                           HorizontalAlignment="Stretch" Margin="0,32,0,0" Appearance="Danger">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:SymbolIcon Symbol="Delete24" Margin="0,0,8,0" />
                        <TextBlock Text="Clear Chat History" />
                    </StackPanel>
                </ui:Button>
            </StackPanel>

            <!-- Chat History Box -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ListView ItemsSource="{Binding ChatHistory}"
                          BorderThickness="0"
                          Background="Transparent"
                          Padding="16"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,8">
                                <TextBlock Text="{Binding Role, Converter={StaticResource CapitalizeConverter}}" 
                                           FontWeight="SemiBold" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Content}" 
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <!-- Input Box -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <ui:TextBox Grid.Column="0" 
                        Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" 
                        PlaceholderText="Ask the IT Assistant anything..." 
                        AcceptsReturn="True"
                        MinHeight="80"
                        TextWrapping="Wrap" />
                        
            <ui:Button Grid.Column="2" 
                       Appearance="Primary" 
                       Command="{Binding SendMessageCommand}" 
                       IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"
                       VerticalAlignment="Bottom">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Send24" Margin="0,0,8,0" />
                    <TextBlock Text="Send Message" />
                </StackPanel>
            </ui:Button>
            
            <ui:ProgressRing Grid.Column="2" 
                             IsIndeterminate="True" 
                             Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}" 
                             Margin="0,0,0,16" 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Top" />
        </Grid>

    </Grid>
</Page>
