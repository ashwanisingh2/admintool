<Page
    x:Class="SysAdminX.NetworkToolkit.Views.NetworkToolkitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SysAdminX.NetworkToolkit.ViewModels"
    mc:Ignorable="d"
    Title="Network Toolkit"
    Loaded="OnPageLoaded"
    d:DataContext="{d:DesignInstance vm:NetworkToolkitViewModel, IsDesignTimeCreatable=False}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid>
        <!-- Loading Overlay -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="10"
              Background="{DynamicResource ApplicationBackgroundBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
                <TextBlock Text="Analyzing network..."
                           Margin="0,16,0,0"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Error State -->
        <Grid Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="5">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Warning24" FontSize="48"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,12,0,0"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="400" />
                <ui:Button Content="Retry"
                           Margin="0,16,0,0"
                           HorizontalAlignment="Center"
                           Appearance="Primary"
                           Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Network Toolkit"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Manage adapters and monitor active connections"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Appearance="Primary"
                               Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" Margin="0,0,8,0" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                
                <!-- Adapters Tab -->
                <TabItem Header="Adapters">
                    <DataGrid ItemsSource="{Binding Adapters}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                              Margin="0,16,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" />
                            <DataGridTextColumn Header="IPv4 Address" Binding="{Binding IPv4Address}" Width="1*" />
                            <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="1*" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                
                <!-- Connections Tab -->
                <TabItem Header="Active Connections">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <ui:TextBox Grid.Row="0"
                                    PlaceholderText="Search connections by process or IP..."
                                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                    Icon="{ui:SymbolIcon Search24}"
                                    Width="300"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,16" />

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Connections}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="0.8*" />
                                <DataGridTextColumn Header="Local Address" Binding="{Binding LocalAddress}" Width="1.5*" />
                                <DataGridTextColumn Header="Remote Address" Binding="{Binding RemoteAddress}" Width="1.5*" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="1*" />
                                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="1.5*" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="0.8*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <!-- Port Scanner Tab -->
                <TabItem Header="Port Scanner">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <ui:Card Grid.Row="0" Margin="0,0,0,16" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Scan Configuration" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Target IP" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBox PlaceholderText="e.g. 127.0.0.1"
                                                    Text="{Binding ScannerTarget, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="200" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Start Port" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBox PlaceholderText="e.g. 1"
                                                    Text="{Binding ScannerStartPort, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="100" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="End Port" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBox PlaceholderText="e.g. 1000"
                                                    Text="{Binding ScannerEndPort, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="100" />
                                    </StackPanel>
                                    <ui:Button Content="Start Scan" Appearance="Primary" Command="{Binding StartPortScanCommand}" VerticalAlignment="Bottom" />
                                    <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24" Margin="16,0,0,0" VerticalAlignment="Bottom" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ScanResults}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="100" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                                <DataGridTextColumn Header="Service / Details" Binding="{Binding Service}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <!-- Wi-Fi Analyzer Tab -->
                <TabItem Header="Wi-Fi Analyzer">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:Button Content="Scan Wi-Fi Networks" Appearance="Primary" Command="{Binding ScanWiFiCommand}" />
                            <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24" Margin="16,0,0,0" Visibility="{Binding IsScanningWiFi, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding WiFiNetworks}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="2*" />
                                <DataGridTextColumn Header="BSSID" Binding="{Binding Bssid}" Width="1.5*" />
                                <DataGridTextColumn Header="Signal (%)" Binding="{Binding SignalStrength}" Width="1*" />
                                <DataGridTextColumn Header="Channel" Binding="{Binding Channel}" Width="1*" />
                                <DataGridTextColumn Header="Authentication" Binding="{Binding Authentication}" Width="1.5*" />
                                <DataGridTextColumn Header="Encryption" Binding="{Binding Encryption}" Width="1.5*" />
                                <DataGridTextColumn Header="Type" Binding="{Binding NetworkType}" Width="1*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                
                <!-- Wake-on-LAN Tab -->
                <TabItem Header="Wake-on-LAN">
                    <Grid Margin="0,16,0,0">
                        <ui:Card VerticalAlignment="Top" HorizontalAlignment="Left" Padding="24" Width="500">
                            <StackPanel>
                                <TextBlock Text="Wake-on-LAN (Magic Packet)" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Send a magic packet to a device on your network to wake it up." TextWrapping="Wrap" Margin="0,0,0,24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                
                                <TextBlock Text="MAC Address" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:TextBox PlaceholderText="e.g. 00:11:22:33:44:55"
                                            Text="{Binding WolMacAddress, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="0,0,0,24" />
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24" Margin="0,0,16,0" Visibility="{Binding IsSendingWol, Converter={StaticResource BoolToVis}}" />
                                    <ui:Button Content="Send Wake-on-LAN" Appearance="Primary" Command="{Binding SendWakeOnLanCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>
                    </Grid>
                </TabItem>
                
                <!-- IP Subnet Scanner Tab -->
                <TabItem Header="IP Subnet Scanner">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <ui:Card Grid.Row="0" Margin="0,0,0,16" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Ping Sweep Configuration" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Base IP / Subnet" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBox PlaceholderText="e.g. 192.168.1.0"
                                                    Text="{Binding PingSweepBaseIP, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="200" />
                                    </StackPanel>
                                    <ui:Button Content="Start Ping Sweep" Appearance="Primary" Command="{Binding StartPingSweepCommand}" VerticalAlignment="Bottom" />
                                    <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24" Margin="16,0,0,0" VerticalAlignment="Bottom" Visibility="{Binding IsPingSweeping, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding PingSweepResults}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                  Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="IP Address" Binding="{Binding IPAddress}" Width="200" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150" />
                                <DataGridTextColumn Header="Roundtrip Time (ms)" Binding="{Binding RoundtripTime}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Page>

