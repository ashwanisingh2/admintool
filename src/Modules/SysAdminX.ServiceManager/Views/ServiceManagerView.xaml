<Page
    x:Class="SysAdminX.ServiceManager.Views.ServiceManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:SysAdminX.ServiceManager.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    Loaded="OnPageLoaded"
    d:DataContext="{d:DesignInstance Type=viewmodels:ServiceManagerViewModel, IsDesignTimeCreatable=False}"
    Title="Service Manager">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Windows Services"
            FontSize="28"
            FontWeight="SemiBold"
            Margin="0,0,0,16" />

        <ui:InfoBar 
            Grid.Row="1"
            IsOpen="{Binding HasError}"
            Message="{Binding ErrorMessage}"
            Severity="Error"
            Margin="0,0,0,16" />
            
        <!-- Action Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox
                Grid.Column="0"
                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Search services by name or description..."
                Icon="{ui:SymbolIcon Search24}"
                Width="300"
                HorizontalAlignment="Left" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button
                    Command="{Binding LoadServicesCommand}"
                    Icon="{ui:SymbolIcon ArrowClockwise24}"
                    Content="Refresh" />
            </StackPanel>
        </Grid>

        <!-- Data Grid -->
        <ui:DataGrid
            Grid.Row="2"
            ItemsSource="{Binding FilteredServices}"
            SelectedItem="{Binding SelectedService}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            SelectionMode="Single"
            CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="250" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                <DataGridTextColumn Header="Startup Type" Binding="{Binding StartType}" Width="100" />
                <DataGridTextColumn Header="Log On As" Binding="{Binding StartName}" Width="150" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
            </DataGrid.Columns>
        </ui:DataGrid>

        <!-- Bottom Action Bar (Context sensitive) -->
        <ui:Card Grid.Row="3" Margin="0,16,0,0" IsEnabled="{Binding HasSelection}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Service Actions:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                    
                    <ui:Button
                        Command="{Binding StartServiceCommand}"
                        Content="Start"
                        Icon="{ui:SymbolIcon Play24}"
                        Appearance="Success"
                        IsEnabled="{Binding SelectedService.IsStopped}"
                        Margin="0,0,8,0" />
                        
                    <ui:Button
                        Command="{Binding StopServiceCommand}"
                        Content="Stop"
                        Icon="{ui:SymbolIcon Stop24}"
                        Appearance="Danger"
                        IsEnabled="{Binding SelectedService.IsRunning}"
                        Margin="0,0,8,0" />
                        
                    <ui:Button
                        Command="{Binding RestartServiceCommand}"
                        Content="Restart"
                        Icon="{ui:SymbolIcon ArrowClockwise24}"
                        Appearance="Primary"
                        IsEnabled="{Binding SelectedService.IsRunning}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Startup Type:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                    
                    <ui:Button Command="{Binding ChangeStartupTypeCommand}" CommandParameter="Automatic" Content="Auto" Margin="0,0,8,0" />
                    <ui:Button Command="{Binding ChangeStartupTypeCommand}" CommandParameter="Manual" Content="Manual" Margin="0,0,8,0" />
                    <ui:Button Command="{Binding ChangeStartupTypeCommand}" CommandParameter="Disabled" Content="Disable" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- Loading overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
