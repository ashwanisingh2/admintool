<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
        =========================================================
        1. PAGE LOAD STAGGER (RepairCard entrance) 
        NOTE: BeginTime must be staggered per-item in code-behind or behavior 
              since XAML cannot do dynamic math (index * 30ms).
              This Storyboard handles the individual card animation.
        =========================================================
    -->
    <Storyboard x:Key="CardEntranceAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="20" To="0" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 
        =========================================================
        2. BUTTON PRESS FEEDBACK 
        Usage: Use within a ControlTemplate's Triggers.
        =========================================================
    -->
    <Storyboard x:Key="ButtonPressDown">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="0.96" Duration="0:0:0.080" />
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="0.96" Duration="0:0:0.080" />
    </Storyboard>

    <Storyboard x:Key="ButtonPressUp">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1.0" Duration="0:0:0.120">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1.0" Duration="0:0:0.120">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 
        =========================================================
        3. STATUS TRANSITION (NotRun -> Running -> Fixed/Failed)
        Usage: Handled via VisualStateManager inside a ControlTemplate.
        The flicker animation applies to a specific element (e.g. LeftBorderIndicator).
        =========================================================
    -->
    <Storyboard x:Key="StatusRunningFlicker" RepeatBehavior="Forever">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.6" To="1.0" Duration="0:0:0.8" AutoReverse="True" />
    </Storyboard>
    
    <Storyboard x:Key="StatusCrossFade">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         Duration="0:0:0.150" />
    </Storyboard>

    <!-- 
        =========================================================
        4. PROGRESS BAR SHIMMER (while running)
        Usage: Target a LinearGradientBrush with GradientStops. 
        =========================================================
    -->
    <!-- Timeline.DesiredFrameRate is set to 30 for performance -->
    <Storyboard x:Key="ProgressBarShimmer" RepeatBehavior="Forever" Timeline.DesiredFrameRate="30">
        <!-- Assuming the brush has mapping mode RelativeToBoundingBox -->
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Background).(LinearGradientBrush.StartPoint).X"
                         From="-0.5" To="1.5" Duration="0:0:1.5" />
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Background).(LinearGradientBrush.EndPoint).X"
                         From="-0.2" To="1.8" Duration="0:0:1.5" />
    </Storyboard>

    <!-- 
        =========================================================
        5. LOG ENTRY SLIDE-IN
        Usage: Apply to EventTrigger RoutedEvent="Loaded" on the DataTemplate for Log Entries.
        =========================================================
    -->
    <Storyboard x:Key="LogEntrySlideIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.1">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                         From="30" To="0" Duration="0:0:0.1">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 
        =========================================================
        6. SIDEBAR HOVER INDICATOR
        Usage: Triggered on MouseEnter/MouseLeave in a ControlTemplate.
        =========================================================
    -->
    <Storyboard x:Key="SidebarHoverEnter">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         Storyboard.TargetName="LeftAccentBar"
                         From="0" To="1" Duration="0:0:0.1">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <ColorAnimation Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                        Storyboard.TargetName="SidebarItemContainer"
                        To="#20FFFFFF" Duration="0:0:0.1" /> <!-- Replace #20FFFFFF with your SurfaceHover color -->
    </Storyboard>

    <Storyboard x:Key="SidebarHoverLeave">
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         Storyboard.TargetName="LeftAccentBar"
                         To="0" Duration="0:0:0.1">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <ColorAnimation Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                        Storyboard.TargetName="SidebarItemContainer"
                        To="Transparent" Duration="0:0:0.1" />
    </Storyboard>

    <!-- 
        =========================================================
        7. MODAL OVERLAY APPEAR
        Usage: Trigger on IsOpen property change of a Modal control.
        =========================================================
    -->
    <Storyboard x:Key="ModalOverlayAppear">
        <!-- Fade in Overlay Background -->
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         Storyboard.TargetName="OverlayBackground"
                         From="0" To="0.7" Duration="0:0:0.15" />
                         
        <!-- Scale and Fade in Dialog Card -->
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         Storyboard.TargetName="DialogCard"
                         From="0" To="1" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         Storyboard.TargetName="DialogCard"
                         From="0.95" To="1.0" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         Storyboard.TargetName="DialogCard"
                         From="0.95" To="1.0" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 
        =========================================================
        8. TOAST NOTIFICATION
        Usage: Triggered when Toast control is Loaded. Disappears automatically.
        =========================================================
    -->
    <Storyboard x:Key="ToastNotificationAnimate">
        <!-- Slide and Fade In -->
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="-50" To="0" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        
        <!-- Auto-dismiss after 3 seconds -->
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         BeginTime="0:0:3" From="1" To="0" Duration="0:0:0.3">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseIn" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         BeginTime="0:0:3" To="-50" Duration="0:0:0.3">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseIn" />
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

</ResourceDictionary>
